# Required — powers all AI features
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gmail OAuth2 — OAuth client secrets JSON from Google Cloud Console (not the user token)
GMAIL_SENDER_EMAIL=hamza@logiq.org.uk
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","redirect_uris":["http://localhost:8000/api/auth/gmail/callback"]}}
# Platform sender OAuth token (authorise hamza@logiq.org.uk once; paste creds JSON here for welcome emails)
GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.send"],"expiry":"..."}
# Per-user tokens stored in Supabase user_integrations after OAuth (token.json used as legacy fallback)

