{
  "version": 2,
  "builds": [
    { "src": "api/ping.py", "use": "@vercel/python" },
    { "src": "api/health.py", "use": "@vercel/python" },
    { "src": "api/config.py", "use": "@vercel/python" },
    { "src": "api/chat.py", "use": "@vercel/python" },
    {
      "src": "api/auth/hook/user-created.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/gmail_send.py,api/hook_handler.py"
      }
    },
    {
      "src": "api/auth.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/hook_handler.py,api/gmail_send.py"
      }
    },
    {
      "src": "api/gmail_auth.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/google_oauth.py,api/supabase_rest.py,api/http_auth.py"
      }
    },
    {
      "src": "api/sheets.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/sheets_service.py,api/google_oauth.py,api/supabase_rest.py,api/http_auth.py"
      }
    },
    {
      "src": "api/send_gmail.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/google_oauth.py,api/supabase_rest.py,api/http_auth.py"
      }
    },
    {
      "src": "api/calendar.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/google_oauth.py,api/supabase_rest.py,api/http_auth.py"
      }
    },
    {
      "src": "api/agent_run.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/http_auth.py,api/supabase_rest.py,api/google_oauth.py"
      }
    },
    {
      "src": "api/integrations_config.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/google_oauth.py,api/supabase_rest.py,api/http_auth.py"
      }
    },
    { "src": "api/billing_status.py", "use": "@vercel/python" },
    { "src": "api/audit_log.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/hook/user-created", "dest": "/api/auth/hook/user-created.py" },
    { "src": "/api/auth/hook/user-created/", "dest": "/api/auth/hook/user-created.py" },
    { "src": "/api/ping", "dest": "/api/ping.py" },
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/config", "dest": "/api/config.py" },
    { "src": "/api/chat", "dest": "/api/chat.py" },
    { "src": "/api/agent/run", "dest": "/api/agent_run.py" },
    { "src": "/api/send/gmail", "dest": "/api/send_gmail.py" },
    { "src": "/api/billing/status", "dest": "/api/billing_status.py" },
    { "src": "/api/integrations/config", "dest": "/api/integrations_config.py" },
    { "src": "/api/integrations/sheets/connect", "dest": "/api/sheets.py" },
    { "src": "/api/integrations/sheets/read", "dest": "/api/sheets.py" },
    { "src": "/api/integrations/sheets/poll", "dest": "/api/sheets.py" },
    { "src": "/api/integrations/sheets/status", "dest": "/api/sheets.py" },
    { "src": "/api/integrations/sheets/write", "dest": "/api/sheets.py" },
    { "src": "/api/integrations/calendar/availability", "dest": "/api/calendar.py" },
    { "src": "/api/integrations/calendar/events", "dest": "/api/calendar.py" },
    { "src": "/api/integrations/calendar/status", "dest": "/api/calendar.py" },
    { "src": "/api/audit/log", "dest": "/api/audit_log.py" },
    { "src": "/api/auth/gmail/connect", "dest": "/api/gmail_auth.py" },
    { "src": "/api/auth/gmail/callback", "dest": "/api/gmail_auth.py" },
    { "src": "/api/auth/gmail/status", "dest": "/api/gmail_auth.py" },
    { "src": "/api/auth/signup", "dest": "/api/auth.py" },
    { "src": "/api/auth/login", "dest": "/api/auth.py" },
    { "src": "/api/auth/logout", "dest": "/api/auth.py" },
    { "src": "/api/auth/me", "dest": "/api/auth.py" },
    { "src": "/api/auth/profile", "dest": "/api/auth.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "rewrites": [
    { "source": "/api/auth/hook/user-created", "destination": "/api/auth/hook/user-created.py" }
  ]
}
