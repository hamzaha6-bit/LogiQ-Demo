{
  "version": 2,
  "builds": [
    { "src": "api/app.py", "use": "@vercel/python", "config": { "includeFiles": "api_lib/billing_checkout.py,api_lib/billing_webhook.py,api_lib/entitlements.py,api_lib/http_auth.py,api_lib/stripe_client.py,api_lib/supabase_rest.py,api_lib/tiers.py" } },
    {
      "src": "api/auth.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api_lib/action_registry.py,api_lib/gmail_oauth.py,api_lib/gmail_send.py,api_lib/google_oauth.py,api_lib/hook_handler.py,api_lib/http_auth.py,api_lib/supabase_rest.py,api_lib/sheets_service.py"
      }
    },
    {
      "src": "api/integrations.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api_lib/action_registry.py,api_lib/gmail_oauth.py,api_lib/gmail_send.py,api_lib/google_oauth.py,api_lib/hook_handler.py,api_lib/http_auth.py,api_lib/supabase_rest.py,api_lib/sheets_service.py"
      }
    },
    {
      "src": "api/ai.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api_lib/action_registry.py,api_lib/http_auth.py,api_lib/supabase_rest.py"
      }
    },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/hook/user-created", "dest": "/api/auth.py" },
    { "src": "/api/auth/hook/user-created/", "dest": "/api/auth.py" },
    { "src": "/api/ping", "dest": "/api/app.py" },
    { "src": "/api/health", "dest": "/api/app.py" },
    { "src": "/api/config", "dest": "/api/app.py" },
    { "src": "/api/billing/status", "dest": "/api/app.py" },
    { "src": "/api/billing/checkout", "dest": "/api/app.py" },
    { "src": "/api/billing/webhook", "dest": "/api/app.py" },
    { "src": "/api/audit/log", "dest": "/api/app.py" },
    { "src": "/api/workflows/emergency-stop", "dest": "/api/app.py" },
    { "src": "/api/auth/profile", "dest": "/api/auth.py" },
    { "src": "/api/chat/test", "dest": "/api/ai.py" },
    { "src": "/api/chat", "dest": "/api/ai.py" },
    { "src": "/api/agent/run", "dest": "/api/ai.py" },
    { "src": "/api/send/gmail", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/config", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/sheets/connect", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/sheets/read", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/sheets/poll", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/sheets/status", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/sheets/write", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/calendar/availability", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/calendar/events", "dest": "/api/integrations.py" },
    { "src": "/api/integrations/calendar/status", "dest": "/api/integrations.py" },
    { "src": "/api/auth/gmail/connect", "dest": "/api/auth.py" },
    { "src": "/api/auth/gmail/callback", "dest": "/api/auth.py" },
    { "src": "/api/auth/gmail/status", "dest": "/api/auth.py" },
    { "src": "/api/auth/gmail/disconnect", "dest": "/api/auth.py" },
    { "src": "/api/auth/signup", "dest": "/api/auth.py" },
    { "src": "/api/auth/login", "dest": "/api/auth.py" },
    { "src": "/api/auth/logout", "dest": "/api/auth.py" },
    { "src": "/api/auth/me", "dest": "/api/auth.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "rewrites": [
    { "source": "/api/auth/hook/user-created", "destination": "/api/auth.py" }
  ]
}
